# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# ═══════════════════════════════════════════════════
# Wayfair Service Pro Auto-Claim Bot
# ═══════════════════════════════════════════════════

# Обязательно: учётные данные Wayfair Service Pro
WAYFAIR_EMAIL=your_email@example.com
WAYFAIR_PASSWORD=your_password

# Опционально: интервал опроса в секундах (по умолчанию 2)
# POLL_INTERVAL_SECONDS=2

# Опционально: лимит повторных попыток claim (по умолчанию 3)
# CLAIM_RETRY_LIMIT=3

# Опционально: таймаут HTTP-запросов в секундах (по умолчанию 15)
# REQUEST_TIMEOUT=15

# Опционально: путь к файлу логов (по умолчанию wayfair_bot.log)
# LOG_FILE=wayfair_bot.log

# Опционально: уровень логирования (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Опционально: запас времени до истечения токена для обновления (сек, по умолчанию 300)
# TOKEN_REFRESH_MARGIN=300
